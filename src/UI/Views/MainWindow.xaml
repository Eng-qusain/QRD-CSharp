<Window x:Class="QRD.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:QRD.UI.Views"
        Title="QRD — Quantum Repo Documenter"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0D1117">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="⬡ QRD" FontSize="20" FontWeight="Bold"
                               Foreground="#58A6FF"/>
                    <TextBlock Text="Quantum Repo Documenter" FontSize="10"
                               Foreground="#8B949E" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <Button x:Name="NavDashboard" Style="{StaticResource NavButton}"
                            Click="NavDashboard_Click">
                        <TextBlock>📊  Dashboard</TextBlock>
                    </Button>
                    <Button x:Name="NavScanner" Style="{StaticResource NavButton}"
                            Click="NavScanner_Click">
                        <TextBlock>🔍  Scanner</TextBlock>
                    </Button>
                    <Button x:Name="NavExport" Style="{StaticResource NavButton}"
                            Click="NavExport_Click">
                        <TextBlock>📄  Export</TextBlock>
                    </Button>
                    <Button x:Name="NavSettings" Style="{StaticResource NavButton}"
                            Click="NavSettings_Click">
                        <TextBlock>⚙️  Settings</TextBlock>
                    </Button>
                </StackPanel>

                <!-- Status bar at bottom of sidebar -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                    <Separator Background="#21262D" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ApiStatusText" FontSize="11"
                               Foreground="#8B949E" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Content area ─────────────────────────────────────────────── -->
        <Frame x:Name="ContentFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
