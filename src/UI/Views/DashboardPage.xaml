<Page x:Class="QRD.UI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <ScrollViewer>
        <StackPanel Margin="24">
            <!-- Hero -->
            <TextBlock Text="⬡ QRD" FontSize="36" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Quantum Repo Documenter" FontSize="18"
                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Convert any software project into professional PDF documentation — automatically."
                       FontSize="14" Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,32"/>

            <!-- Feature cards -->
            <TextBlock Text="Features" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
            <UniformGrid Columns="3" Margin="0,0,0,32">
                <Border Margin="0,0,12,12" Padding="16" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🔍 Project Scanner" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="Recursive folder tree, language detection, line counts, real-time progress."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,12" Padding="16" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📄 PDF Export" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="Syntax-highlighted code, TOC, stats charts, 4 themes, 4 export modes."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,0,12" Padding="16" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🤖 AI Summaries" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="Per-file AI documentation via Claude or GPT-4o-mini. Optional — works without API key."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" Padding="16" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📊 Data Files" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="CSV, Excel, Parquet previews with schema and sample rows."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,12,0" Padding="16" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🛢️ Petroleum Data" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="LAS/DLIS well log parsing with curve list and quick-look plots."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,0,0" Padding="16" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🖼️ Images" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="PNG, JPG, WEBP embedded as gallery pages in the PDF."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick start -->
            <TextBlock Text="Quick Start" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
            <Border Padding="16" CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontFamily="Courier New" FontSize="12"
                               Foreground="{StaticResource TextBrush}">
                        1. Click Scanner → browse to your project folder → Scan&#x0A;
                        2. Click Export → configure options → Start Export&#x0A;
                        3. Your PDF(s) appear in ~/Documents/QRD (or your chosen output)&#x0A;&#x0A;
                        No Python runtime or Node.js required — everything runs natively.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- API status -->
            <Border x:Name="AiSetupHint" Padding="16" Margin="0,16,0,0"
                    CornerRadius="8" Background="#FFF8E1"
                    BorderBrush="#F59E0B" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⚠ AI summaries disabled" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"
                               Text="Add ANTHROPIC_API_KEY to appsettings.json (or as environment variable) to enable AI-powered per-file documentation. Export PDFs work fine without it."/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
