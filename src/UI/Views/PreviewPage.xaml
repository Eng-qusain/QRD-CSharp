<Page x:Class="QRD.UI.Views.PreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <Page.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="14"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
            <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left panel: options -->
            <ColumnDefinition Width="300" MinWidth="240" MaxWidth="380"/>
            <!-- Splitter -->
            <ColumnDefinition Width="5"/>
            <!-- Right panel: preview -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: Format controls ══════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">

                <TextBlock Text="Preview &amp; Format" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>

                <!-- Project path -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Project" Style="{StaticResource Label}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProjectPathBox" Padding="8,6"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Margin="0,0,6,0" ToolTip="Project folder to preview"/>
                            <Button Grid.Column="1" Content="…" Width="32"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BrowseProject_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Theme -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Theme" Style="{StaticResource Label}"/>
                        <ComboBox x:Name="ThemeCombo" SelectedIndex="0"
                                  SelectionChanged="Option_Changed">
                            <ComboBoxItem Content="Default (GitHub Light)" Tag="default"/>
                            <ComboBoxItem Content="Dark (GitHub Dark)"     Tag="dark"/>
                            <ComboBoxItem Content="GitHub"                 Tag="github"/>
                            <ComboBoxItem Content="Monokai"                Tag="monokai"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Font size -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Label}">
                            Font Size: <Run x:Name="FontSizeLabel">9</Run> pt
                        </TextBlock>
                        <Slider x:Name="FontSizeSlider" Minimum="6" Maximum="14" Value="9"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="FontSlider_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Paper -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Paper" Style="{StaticResource Label}"/>
                        <ComboBox x:Name="PaperCombo" SelectedIndex="0"
                                  SelectionChanged="Option_Changed">
                            <ComboBoxItem Content="A4"/>
                            <ComboBoxItem Content="Letter"/>
                            <ComboBoxItem Content="A3"/>
                        </ComboBox>
                        <ComboBox x:Name="OrientationCombo" SelectedIndex="0" Margin="0,8,0,0"
                                  SelectionChanged="Option_Changed">
                            <ComboBoxItem Content="Portrait"/>
                            <ComboBoxItem Content="Landscape"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Toggles -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Content" Style="{StaticResource Label}"/>
                        <CheckBox x:Name="ChkToc"      Content="Table of Contents"   IsChecked="True" Margin="0,3" Click="Option_Changed"/>
                        <CheckBox x:Name="ChkStats"    Content="Project Statistics"   IsChecked="True" Margin="0,3" Click="Option_Changed"/>
                        <CheckBox x:Name="ChkAi"       Content="AI Summaries"         IsChecked="True" Margin="0,3" Click="Option_Changed"/>
                        <CheckBox x:Name="ChkSyntax"   Content="Syntax Highlighting"  IsChecked="True" Margin="0,3" Click="Option_Changed"/>
                        <CheckBox x:Name="ChkLineNums" Content="Line Numbers"          IsChecked="True" Margin="0,3" Click="Option_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Max lines -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Label}">
                            Max Lines / File: <Run x:Name="MaxLinesLabel">200</Run>
                        </TextBlock>
                        <Slider x:Name="MaxLinesSlider" Minimum="20" Maximum="2000" Value="200"
                                TickFrequency="20" IsSnapToTickEnabled="True"
                                ValueChanged="MaxLines_Changed"/>
                        <TextBlock Text="(preview uses a lower cap; export uses full value)"
                                   FontSize="10" Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Notes editor -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Cover Page Note" Style="{StaticResource Label}"/>
                        <TextBox x:Name="CoverNoteBox" Height="60" AcceptsReturn="True"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Padding="8,6" BorderBrush="{StaticResource BorderBrush}"
                                 ToolTip="Optional note shown below stats on the cover page"
                                 TextChanged="Option_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Margin="0,4,0,0">
                    <Button x:Name="RefreshBtn" Content="↺  Refresh Preview"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8" Click="Refresh_Click"/>
                    <Button x:Name="ExportBtn"  Content="▶  Export PDF with These Settings"
                            Style="{StaticResource PrimaryButton}"
                            Click="Export_Click"/>
                </StackPanel>

                <!-- Status -->
                <TextBlock x:Name="StatusLabel" Margin="0,12,0,0" TextWrapping="Wrap"
                           FontSize="11" Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

        <!-- ══ RIGHT: Preview area ════════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Live Preview" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PreviewInfoLabel" Margin="12,0,0,0"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="PreviewProgress" Width="120" Height="6" Margin="12,0,0,0"
                                 Visibility="Collapsed" IsIndeterminate="True"
                                 Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>

            <!-- The preview itself — a FlowDocumentScrollViewer renders rich formatted content -->
            <Grid Grid.Row="1" x:Name="PreviewGrid" Background="#F0F0F0">

                <!-- Placeholder -->
                <StackPanel x:Name="PlaceholderPanel" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a project folder and click Refresh Preview"
                               Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Rendered preview document -->
                <FlowDocumentScrollViewer x:Name="PreviewViewer"
                                          Visibility="Collapsed"
                                          Background="White"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          Zoom="100" IsToolBarVisible="True">
                    <FlowDocumentScrollViewer.Document>
                        <FlowDocument x:Name="PreviewDoc" PageWidth="794"
                                      ColumnWidth="794" ColumnGap="0"
                                      FontFamily="Arial" FontSize="10"/>
                    </FlowDocumentScrollViewer.Document>
                </FlowDocumentScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
